{
    "name": "spider-themes/eazydocs",
    "description": "EazyDocs is a modern, feature-rich documentation plugin for WordPress. Create professional knowledge bases, FAQs, and help centers with ease.",
    "type": "wordpress-plugin",
    "license": "GPLv2",
    "authors": [
        {
            "name": "Spider Themes",
            "email": "spiderthemes@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "freemius/wordpress-sdk": "^2.13",
        "league/commonmark": "^2.8.2",
        "league/html-to-markdown": "^5.1"
    },
    "autoload": {
        "psr-4": {
            "EazyDocs\\": "includes/"
        },
        "files": []
    },
    "config": {
        "platform": {
            "php": "8.1.0"
        }
    }
}
